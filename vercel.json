{
    "version": 2,
    "builds": [
        {
            "src": "Bachelor_life_backend/main.py",
            "use": "@vercel/python"
        },
        {
            "src": "Bachelor_life_frontend/**/*",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/static/(.*)",
            "dest": "Bachelor_life_backend/static/$1"
        },
        {
            "src": "/(user|owner|room|rooms|booking|ping|init-db|user-dashboard|fix-images|fix-db)(/.*)?",
            "dest": "Bachelor_life_backend/main.py"
        },
        {
            "src": "/pages/(.*)",
            "dest": "Bachelor_life_frontend/pages/$1"
        },
        {
            "src": "/(.*).html",
            "dest": "Bachelor_life_frontend/$1.html"
        },
        {
            "src": "/",
            "dest": "Bachelor_life_frontend/index.html"
        },
        {
            "src": "/(.*)",
            "dest": "Bachelor_life_frontend/$1"
        }
    ]
}